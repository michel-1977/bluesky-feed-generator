# Whichever port you want to run this on
FEEDGEN_PORT=3000

# Change this to use a different bind address
FEEDGEN_LISTENHOST="localhost"

# Local SQLite path used at runtime. Keep this on the container filesystem.
FEEDGEN_SQLITE_LOCATION="db.sqlite"

# Optional persistent copy location. In Azure Container Apps, point this at a mounted Azure Files path.
# Example: /app/data/db.sqlite
FEEDGEN_SQLITE_BACKUP_LOCATION=""

# How often to flush pending DB changes to the persistent copy when writes occur.
FEEDGEN_SQLITE_BACKUP_INTERVAL_MS=15000

# Don't change unless you're working in a different environment than the primary Bluesky network
FEEDGEN_SUBSCRIPTION_ENDPOINT="wss://bsky.network"

# Set this to the hostname that you intend to run the service at
FEEDGEN_HOSTNAME="example.com"

# Set this to the DID of the account you'll use to publish the feed
# You can find your account DID by going to:
# https://bsky.social/xrpc/com.atproto.identity.resolveHandle?handle=${YOUR_HANDLE}
FEEDGEN_PUBLISHER_DID="did:plc:abcde...."

# Only use this if you want a service DID different from did:web
# FEEDGEN_SERVICE_DID="did:plc:abcde..."

# Delay between reconnect attempts to the firehose subscription endpoint (in milliseconds)
FEEDGEN_SUBSCRIPTION_RECONNECT_DELAY=3000

# Feed settings
# Keep this in sync with the record name (rkey) used during publish
FEEDGEN_FEED_SHORTNAME="mobility-risk"

# Optional additive custom signals. These are no longer the primary gate.
FEEDGEN_KEYWORDS="atropello,incidencia en renfe,retenciones,carretera cortada"

# Optional BCP-47 language allowlist. Leave empty to accept all languages.
FEEDGEN_LANG_ALLOWLIST="es"

# Rule-based score thresholds.
# < FEEDGEN_RULE_LLM_MIN_SCORE is rejected.
# >= FEEDGEN_RULE_AUTO_ACCEPT_SCORE is auto-accepted when the rule classifier is clean.
FEEDGEN_RULE_LLM_MIN_SCORE=60
FEEDGEN_RULE_AUTO_ACCEPT_SCORE=85

# Optional ambiguity review with an LLM.
# If disabled, posts in the review band are rejected for precision.
FEEDGEN_LLM_FILTER_ENABLED=false

# OpenAI-compatible Chat Completions endpoint.
FEEDGEN_LLM_API_URL="https://api.openai.com/v1/chat/completions"
FEEDGEN_LLM_API_KEY=""
FEEDGEN_LLM_MODEL="gpt-4o-mini"

# LLM behavior tuning.
FEEDGEN_LLM_TIMEOUT_MS=5000
FEEDGEN_LLM_MAX_INPUT_CHARS=500
FEEDGEN_LLM_MIN_CONFIDENCE=0.85
FEEDGEN_LLM_FAIL_OPEN=false

# Keep only recent items in the DB
FEEDGEN_MAX_POST_AGE_HOURS=48

# Cap persisted items after filtering. Newest accepted posts are kept (FIFO eviction).
FEEDGEN_MAX_INDEXED_POSTS=500
